rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "dashfire@gmail.com" || 
              request.auth.token.email == "pedro.honorio@gm.rio" ||
              request.auth.token.email == "dahfire@gmail.com") && 
             request.auth.token.email_verified == true;
    }

    // Users data: Isolated by UID
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // System Logs: Only master admin can read everything, users can only write to their own log node
    match /users/{userId}/system_logs/{logId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Keep global logs rule for legacy or system compatibility if needed, 
    // but preferred way is the isolated path above.
    match /system_logs/{logId} {
      allow read: if isMasterAdmin();
      allow create: if true; 
    }

    // Presence: shared for the academy (or also isolated - choosing isolated for now)
    match /presence/{presenceId} {
      allow read, write: if isAuthenticated();
    }
  }
}
