{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Academy members and their progression data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "belt": { "type": "string" },
        "stripes": { "type": "number" },
        "joinDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Suspended", "Waitlist"] },
        "isKid": { "type": "boolean" },
        "nickname": { "type": "string" },
        "responsibleEmail": { "type": "string" },
        "responsiblePhone": { "type": "string" },
        "isWaitlist": { "type": "boolean" },
        "waitlistRank": { "type": "number" },
        "monthlyValue": { "type": "number" },
        "portalAccessCode": { "type": "string" },
        "classId": { "type": "string" },
        "positionVideos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "videoUrl": { "type": "string" },
              "description": { "type": "string" },
              "date": { "type": "string" },
              "authorId": { "type": "string" },
              "authorName": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "name", "belt", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Financial transactions for student tuitions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "method": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "SystemLog": {
      "title": "System Log",
      "description": "Audit logs for security and tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "number" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "ClassSchedule": {
      "title": "Class Schedule",
      "description": "Weekly training timetable.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "time": { "type": "string" },
        "title": { "type": "string" },
        "instructor": { "type": "string" },
        "category": { "type": "string" },
        "days": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "users/{userId}/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of students for a specific sensei."
    },
    "users/{userId}/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Student tuition payments for a specific academy."
    },
    "users/{userId}/system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "Audit trails for a specific sensei."
    },
    "users/{userId}/schedules/{scheduleId}": {
      "schema": "ClassSchedule",
      "description": "Class calendar for a specific academy."
    },
    "users/{userId}/ledger/{ledgerId}": {
      "schema": "TransactionLedger",
      "description": "Immutable transaction ledger."
    },
    "users/{userId}/receipts/{receiptId}": {
      "schema": "PaymentReceipt",
      "description": "Payment receipts uploaded by students."
    },
    "users/{userId}/settings/academy_profile": {
      "schema": "ProfessorProfile",
      "description": "Academy branding and settings."
    }
  }
}
