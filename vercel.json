{
  "version": 2,
  "buildCommand": "DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/sysbjj\" DIRECT_URL=\"postgresql://postgres:postgres@localhost:5432/sysbjj\" prisma generate && vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "ignoreCommand": "exit 1",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!.*\\.[a-z0-9]+$).*)",
      "destination": "/index.html"
    }
  ]
}
