# Supabase App configuration (Frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Database configuration (Prisma Backend)
# Format: postgresql://postgres.[project-id]:[password]@[host]:6543/postgres?pgbouncer=true
DATABASE_URL=
# Format: postgresql://postgres.[project-id]:[password]@[host]:5432/postgres
DIRECT_URL=

# Supabase Auth configuration (optional for additional features)
SUPABASE_CLIENT_ID=
SUPABASE_CLIENT_SECRET=
