# Supabase App configuration (Frontend Auth)
VITE_SUPABASE_URL=https://btohwjzbybrwimrhzthj.supabase.co
VITE_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]
VITE_API_URL="https://seu-backend.run.app"

# Database configuration (Prisma Backend)
# 🥋 OS SENSEI: Use a String de Conexão (URI) do Supabase com o Pooler (Porta 6543).
# Formato: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# ⚠️ IMPORTANTE: Se sua senha tiver @, #, !, use URL Encoding (@ -> %40, # -> %23).
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Usado para migrações Prisma (Opcional, porta 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
