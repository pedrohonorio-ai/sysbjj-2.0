generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/* =========================
   USER (SAAS CORE)
========================= */

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  name           String?
  role           String   @default("admin")

  active         Boolean  @default(true)
  deletedAt      DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lastLoginAt    DateTime?
  lastActivityAt DateTime?

  subscription   Subscription?
  students       Student[] @relation("UserStudents")
}

/* =========================
   SUBSCRIPTION
========================= */

model Subscription {
  id              String   @id @default(cuid())
  userId          String   @unique

  plan            String   @default("FREE")

  studentLimit    Int      @default(20)
  currentStudents Int      @default(0)
  monthlyPrice    Float    @default(0)

  billingCycle    String   @default("MONTHLY")
  status          String   @default("ACTIVE")

  expiresAt       DateTime?
  renewalEnabled  Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/* =========================
   PAYMENT HISTORY
========================= */

model SubscriptionPaymentHistory {
  id           String   @id @default(cuid())
  userId       String
  amount       Float

  date         DateTime @default(now())
  proofUrl     String?
  billingCycle String?
  status       String   @default("APPROVED")

  approvedBy   String?
  notes        String?

  createdAt    DateTime @default(now())

  @@index([userId])
}

/* =========================
   STUDENT (CORE SAAS)
========================= */

model Student {
  id        String @id @default(cuid())
  userId    String

  user      User   @relation("UserStudents", fields: [userId], references: [id], onDelete: Cascade)

  name      String
  nickname  String?
  email     String?
  phone     String?

  birthDate String?
  gender    String?

  cpf       String?
  rg        String?

  weight    Float?
  height    Float?

  category  String?
  belt      String  @default("Branca")

  stripes   Int     @default(0)
  degrees   Int     @default(0)

  status    String  @default("Active")

  monthlyValue Float @default(0)

  attendanceCount Int @default(0)

  behaviorScore   Int @default(0)
  rewardPoints    Int @default(0)

  active    Boolean @default(true)
  isInstructor Boolean @default(false)

  lastSeen  BigInt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendanceHistory Json?
  history          Json?
  techniques       Json?
  goals            Json?
  feedbacks        Json?

  graduationHistoryRecords GraduationHistory[]

  @@index([userId])
  @@index([userId, status])
}

/* =========================
   PAYMENT
========================= */

model Payment {
  id        String   @id @default(cuid())
  userId    String
  studentId String?

  name      String
  amount    Float
  date      String
  method    String
  status    String   @default("Paid")

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([studentId])
}

/* =========================
   PRESENCE (FIXED 100%)
========================= */

model Presence {
  id        String   @id @default(cuid())
  userId    String

  email     String
  role      String?

  lastSeen  BigInt
  userAgent String?
  deviceId  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, deviceId])
  @@index([userId])
}

/* =========================
   GRADUATION
========================= */

model GraduationHistory {
  id              String   @id @default(cuid())
  studentId       String

  previousBelt    String
  newBelt         String

  previousStripes Int @default(0)
  newStripes      Int @default(0)

  promotedAt      DateTime @default(now())
  promotedBy      String?

  notes           String?
  ibjjfValidated  Boolean @default(true)

  student         Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

/* =========================
   NOTIFICATION
========================= */

model Notification {
  id        String   @id @default(cuid())
  userId    String

  title     String
  message   String
  type      String
  priority  String

  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
}
