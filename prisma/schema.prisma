generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//
// ENUMS (padronização enterprise)
//

enum UserRole {
  ADMIN
  MASTER
  USER
  STUDENT
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  EXPIRED
  SUSPENDED
  FREE
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Belt {
  BRANCA
  AZUL
  ROXA
  MARROM
  PRETA
}

enum PresenceRole {
  ADMIN
  USER
  STUDENT
}

//
// USER
//

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      UserRole @default(USER)

  active    Boolean  @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription Subscription?
  students     Student[]
}

//
// SUBSCRIPTION
//

model Subscription {
  id        String @id @default(cuid())
  userId    String @unique

  plan      String @default("FREE")

  status    SubscriptionStatus @default(ACTIVE)

  studentLimit    Int @default(20)
  currentStudents  Int @default(0)

  monthlyPrice Float @default(0)

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//
// STUDENT (CORE DO SISTEMA)
//

model Student {
  id       String @id @default(cuid())
  userId   String

  name     String
  nickname String?

  email    String?
  phone    String?

  birthDate DateTime?

  gender String?
  cpf    String?
  rg     String?

  weight Float?
  height Float?

  belt     Belt @default(BRANCA)
  degrees   Int  @default(0)
  stripes   Int  @default(0)

  status String @default("ACTIVE")

  monthlyValue Float @default(0)

  active Boolean @default(true)

  isInstructor Boolean @default(false)
  isKid        Boolean @default(false)

  behaviorScore Int @default(0)
  rewardPoints  Int @default(0)

  lastSeen DateTime?

  photoUrl String?

  address String?
  city    String?
  state   String?

  lgpdConsent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // JSON FLEX (enterprise)
  attendanceHistory Json?
  techniques        Json?
  goals             Json?
  feedbacks         Json?
  documents         Json?

  graduationHistory GraduationHistory[]

  @@index([userId])
  @@index([userId, active])
}

//
// PRESENCE (CORRIGIDO - seu erro veio daqui)
//

model Presence {
  id        String @id @default(cuid())

  userId    String
  email     String

  role      PresenceRole @default(USER)

  lastSeen  BigInt

  userAgent String?
  deviceId  String

  createdAt DateTime @default(now())   // ✅ FIX DO SEU ERRO
  updatedAt DateTime @updatedAt

  @@unique([email, deviceId])
  @@index([userId])
}

//
// SUBSCRIPTION PAYMENT HISTORY
//

model SubscriptionPaymentHistory {
  id        String @id @default(cuid())
  userId    String

  amount    Float
  status    PaymentStatus @default(APPROVED)

  billingCycle String?

  proofUrl String?
  notes    String?

  createdAt DateTime @default(now())

  @@index([userId])
}

//
// PAYMENT
//

model Payment {
  id        String @id @default(cuid())

  userId    String
  studentId String?

  name      String
  amount    Float

  method    String
  status    PaymentStatus @default(APPROVED)

  reference String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([studentId])
}

//
// SYSTEM LOG
//

model SystemLog {
  id        String @id @default(cuid())

  userId    String
  email     String

  action    String
  category  String
  details   String

  deviceInfo String

  timestamp BigInt

  createdAt DateTime @default(now())

  @@index([userId])
}

//
// GRADUATION HISTORY
//

model GraduationHistory {
  id        String @id @default(cuid())

  studentId String

  previousBelt Belt
  newBelt      Belt

  previousStripes Int @default(0)
  newStripes      Int @default(0)

  notes String?

  promotedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

//
// CLASS SCHEDULE
//

model ClassSchedule {
  id        String @id @default(cuid())

  userId    String

  title     String
  instructor String
  category  String

  days String[]

  time String

  active Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([userId])
}
