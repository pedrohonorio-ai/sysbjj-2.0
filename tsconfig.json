{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "noEmit": true,
    "outDir": "dist-server"
  },
  "exclude": ["scripts", "node_modules", "dist", "vite.config.ts"]
}
